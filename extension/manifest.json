{
  "manifest_version": 3,
  "name": "CVBoost · Analiza ofertas con 1 click",
  "version": "1.0.0",
  "description": "Lee la oferta de empleo de la página actual y ábrela en CVBoost para analizarla contra tu CV.",
  "default_locale": "es",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Analizar esta oferta con CVBoost",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.infojobs.net/*",
    "https://*.glassdoor.com/*",
    "https://*.welcometothejungle.com/*",
    "https://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Analizar esta oferta con CVBoost"
    }
  }
}
